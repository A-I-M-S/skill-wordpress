# --- WordPress -------------------------------------------------------------
WP_HOST=yourdomain.com
WP_USER=your_wp_username
WP_PW=your_wp_application_password
MEDIA_RANGE_START=1000
MEDIA_RANGE_END=2000

# --- LLM (OpenRouter) ------------------------------------------------------
OR_SK=sk-or-xxx
LLM_PRIMARY_MODEL=google/gemini-3.1-flash-lite
LLM_FALLBACK_MODELS=anthropic/claude-3.5-haiku,openai/gpt-4o-mini
LLM_MAX_TOKENS=4000
MIN_WORDS=1200

# --- ByteDance Seedream (image generation) ---------------------------------
SEEDREAM_API_KEY=your_byteplus_ark_api_key
SEEDREAM_ENDPOINT=https://ark.ap-southeast.bytepluses.com/api/v3/images/generations
SEEDREAM_MODEL=seedream-5-0-260128
SEEDREAM_SIZE=2K
SEEDREAM_WATERMARK=true

# --- ByteDance Seedance (video generation, up to 15s) ----------------------
# Used by the YouTube Shorts pipeline. Same API key as Seedream if both are
# on the same BytePlus / Volcano Engine project.
SEEDANCE_API_KEY=your_byteplus_ark_api_key
SEEDANCE_ENDPOINT=https://ark.ap-southeast.bytepluses.com/api/v3/contents/generations/tasks
# Use the pro model for quality, lite-t2v/lite-i2v for cheaper runs.
SEEDANCE_MODEL=dreamina-seedance-2-0-fast-260128
SEEDANCE_RESOLUTION=1080p
# Clamped to 5..15s by the client.
SEEDANCE_DURATION=10
# 9:16 for Shorts, 16:9 for landscape, 1:1 for IG/Threads.
SEEDANCE_RATIO=9:16
# Recommended: false for stability. Native audio fails ~10-20% of runs
# with OutputAudioSensitiveContentDetected. The pipeline auto-falls-back
# to edge-tts even when true, but starting with false is more predictable.
SEEDANCE_GENERATE_AUDIO=false
SEEDANCE_WATERMARK=false

# --- Publishing guardrails (DO NOT raise without thought) ------------------
MAX_POSTS_PER_DAY=4
MIN_MINUTES_BETWEEN_POSTS=240
TITLE_SIM_THRESHOLD=0.80
CATEGORY_FILE=curated_categories.json
AUTHOR_NAME=Aloy CWL
AUTHOR_URL=https://insightginie.com/about

# --- Indexing --------------------------------------------------------------
INDEXNOW_KEY=your_indexnow_key
BING_WMT_API_KEY=your_bing_wmt_key

# --- Distribution flags (true/false) ---------------------------------------
DIST_LINKEDIN=true
DIST_BLUESKY=true
DIST_THREADS=true
DIST_FACEBOOK=true
DIST_TELEGRAM=true
DIST_DISCORD=true
DIST_NOSTR=true
DIST_HASHNODE=true
DIST_REDDIT=false
DIST_HACKERNEWS=true
DIST_YOUTUBE_SHORTS=false
# Video fan-out (re-uploads the same Seedance mp4 to each enabled platform).
# All default off — flip to true once the matching credentials are set.
DIST_INSTAGRAM_REELS=false
DIST_FACEBOOK_REELS=false
DIST_LINKEDIN_VIDEO=false
DIST_THREADS_VIDEO=false
DIST_TIKTOK_DRAFT=false
# Duplicate-content footgun — keep OFF:
DIST_WP_COM=false
# High ban-risk — keep OFF:
DIST_DEVTO=false

# --- Threads (Meta) --------------------------------------------------------
THREADS_TOKEN=your_token
THREADS_ID=your_id

# --- Telegram --------------------------------------------------------------
TELEGRAM_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Discord ---------------------------------------------------------------
DISCORD_TOKEN=your_bot_token
DISCORD_CHANNEL_ID=your_channel_id

# --- Bluesky ---------------------------------------------------------------
BLUESKY_USER=your.handle.bsky.social
BLUESKY_PASS=your_app_password

# --- Hashnode --------------------------------------------------------------
HASHNODE_TOKEN=your_token
HASHNODE_PUBLICATION_ID=your_pub_id

# --- Nostr -----------------------------------------------------------------
NOSTR_KEY=nsec_or_hex_private_key

# --- Reddit safety controls (auth is through Composio OAuth) --------------
# Keep DIST_REDDIT=false until you have manually reviewed target communities.
# Only allow subreddits where self-promotion is explicitly permitted.
REDDIT_ALLOWED_SUBS=u_aloycwl
REDDIT_MIN_INTERVAL_MIN=240

# --- Hacker News (semi-automated via Telegram approval link) ---------------
HN_ENABLED=true
HN_NOTIFY_TELEGRAM_CHAT_ID=

# --- YouTube Shorts --------------------------------------------------------
YOUTUBE_ENABLED=false
YOUTUBE_CLIENT_SECRETS=youtube-client-secrets.json
YOUTUBE_TOKEN_FILE=youtube-token.json
YOUTUBE_PRIVACY=public
YOUTUBE_CATEGORY_ID=28

# --- Legacy / deprecated (kept for compat) ---------------------------------
DEVTO_KEY=
WORDPRESS_COM_USERNAME=
WORDPRESS_COM_TOKEN=

# --- Instagram Reels (uses Meta Graph API) --------------------------------
# Instagram Business or Creator account linked to a Facebook Page.
# INSTAGRAM_TOKEN can be omitted — falls back to FACEBOOK_TOKEN automatically.
# Required scopes on your Meta app: instagram_basic, instagram_content_publish.
INSTAGRAM_USER_ID=
INSTAGRAM_TOKEN=

# --- TikTok (Content Posting API, DRAFT mode only) -----------------------
# Direct-post requires "audited" client_key — months-long approval, rarely
# granted for AI autoposting. DRAFT mode works with un-audited keys and lands
# the video in your TikTok app inbox; you tap "Post" to publish.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO

# --- Composio OAuth integrations -----------------------------------------
# Connect these in Composio; store only account ids here, never provider app keys.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=
COMPOSIO_GSC_ACCOUNT_ID=
COMPOSIO_REDDIT_ACCOUNT_ID=
COMPOSIO_GOOGLE_ANALYTICS_ACCOUNT_ID=
COMPOSIO_GOOGLESHEETS_ACCOUNT_ID=
COMPOSIO_GOOGLEDRIVE_ACCOUNT_ID=
COMPOSIO_GOOGLEDOCS_ACCOUNT_ID=
COMPOSIO_LINKEDIN_ACCOUNT_ID=
COMPOSIO_FACEBOOK_ACCOUNT_ID=
COMPOSIO_YOUTUBE_ACCOUNT_ID=
GSC_SITE_URL=https://insightginie.com/
GA4_PROPERTY=properties/486401787
GROWTH_SHEET_ID=
LINKEDIN_AUTHOR_URN=
FACEBOOK_PAGE_ID=
